{
  "query": {
    "version": "v1",
    "source": "placement",
    "select": ["name", "status", "budget", "campaign.name"],
    "where": {
      "and": [
        { "field": "status", "op": "eq", "value": "active" },
        { "field": "budget", "op": "gte", "value": 10000 },
        { "field": "campaign.name", "op": "contains", "value": "spring" }
      ]
    },
    "orderBy": [{ "field": "budget", "direction": "desc" }],
    "limit": 25
  }
}
