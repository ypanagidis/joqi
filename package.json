{
  "name": "@up/querykit",
  "version": "0.0.0",
  "description": "Driver-based dynamic query runtime for trusted business-owned JSON specs.",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./effect": {
      "types": "./dist/effect.d.ts",
      "import": "./dist/effect.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "format": "oxfmt -c oxfmt.config.ts 'src/**/*.ts' 'test/**/*.ts' '*.json' '*.ts' '*.yaml'",
    "format:check": "oxfmt -c oxfmt.config.ts --check 'src/**/*.ts' 'test/**/*.ts' '*.json' '*.ts' '*.yaml'",
    "lint": "oxlint -c oxlint.config.ts --type-aware",
    "lint:fix": "oxlint -c oxlint.config.ts --type-aware --fix",
    "test": "vitest run",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "effect": "^3.17.0"
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260523.1",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "oxlint-tsgolint": "^0.23.0",
    "tsdown": "^0.15.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.12.1"
}
